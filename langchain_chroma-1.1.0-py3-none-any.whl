<html>
    <head>
        <meta charset="utf-8" />
        <meta name="robots" content="noindex, nofollow" />
        <meta http-equiv="cache-control" content="max-age=0" />
        <meta http-equiv="cache-control" content="no-cache" />
        <meta http-equiv="expires" content="0" />
        <meta http-equiv="expires" content="Tue, 01 Jan 1980 1:00:00 GMT" />
        <meta http-equiv="pragma" content="no-cache" />
        <!--
            Mobile browsers have a "font-boost" effect, where font size (and thus, pixel-
            to-rem ratio) is increased when the orientation is flipped to landscape mode.
            That makes it hard to have elements that are sized relative to display size
            but also maintain their fixed size when orientation changes. The next line
            disables it.
        -->
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Domain Blocked: files.pythonhosted.org</title>
        <style>
            .container {
                position: relative;
                height: 100%;
                font-family: arial;
            }

            .logo-banner {
                margin: 0.5rem;
            }

            .logo-banner img {
                height: 3rem;
            }

            .lock-image {
                margin-right: .5rem;
                height: 2rem;
                width: 1.517rem;
            }

            .centered-text {
                text-align: center;
                width: 100%;
            }

            .main-block {
                margin: 19vh auto;
                width: 18rem;
            }

            .main-block-inner p {
                margin-bottom: 0;
            }

            .lock-image-padding {
                padding: 0 0 0 2rem;
            }

            .warning-text {
                font-size: 1rem;
                position: relative;
            }

            .warning-text img {
                left: 0;
                position: absolute;
                top: 0;
            }

            .domain {
                font-weight: bold;
                font-size: 1rem;
            }

            .help-instructions {
                color: #9B9B9B;
                font-size: 1rem;
                margin-top: 1rem;
            }

            @media screen and (orientation: landscape) {
                .main-block {
                    /* AJB: This is slightly off-spec. The mockups don't
                     *      account for the nav bar taking up a big
                     *      chunk of screen height in landscape mode.
                     *      This keeps it looking good and still pretty
                     *      close to spec.
                     */
                    margin-top: 13vh;
                }
            }

        </style>
    </head>
    <body>
        <div class="container">
            <div class="logo-banner">
                <img src="data:image/png;base64," />
            </div>
            <div class="main-block">
                <div class="main-block-inner">
                    <div class="lock-image-padding warning-text">
                        <img class="lock-image" src="data:image/png;base64," />
                        <p>
                            Your filter settings are currently blocking your access to
                        </p>
                    </div>
                    <div class="lock-image-padding domain">
                        files.pythonhosted.org                    </div>
                    <div class="lock-image-padding help-instructions">
                        Contact your Filter Guardian if you wish to change your blocking level or remove a site from your custom block list.
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>
